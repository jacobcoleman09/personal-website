---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2
              class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold"
              style={`color: ${siteConfig.accentColor}`}
            >
              Education
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background: linear-gradient(90deg, ${siteConfig.accentColor}, #2563EB)`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.education.map((edu, i) => (
                <div
                  class="bg-white rounded-xl shadow-sm border-l-4 border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-lg transition-all duration-300"
                  style={i === 0 ? `border-left-color: ${siteConfig.accentColor}` : `border-left-color: #7C3AED`}
                >
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                      <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                        {edu.degree}
                      </h3>
                      <p
                        class="text-base sm:text-lg font-medium"
                        style={i === 0 ? `color: ${siteConfig.accentColor}` : `color: #7C3AED`}
                      >
                        {edu.school}
                      </p>
                    </div>
                    <span class="text-xs sm:text-sm text-gray-500 mt-2 sm:mt-0 font-mono">
                      {edu.dateRange}
                    </span>
                  </div>

                  <ul class="space-y-2">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start">
                        <span
                          class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0"
                          style={i === 0 ? `background-color: ${siteConfig.accentColor}` : `background-color: #7C3AED`}
                        />
                        <span class="text-sm sm:text-base text-gray-600">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
